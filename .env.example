# Docker Compose environment variables
# Copy to .env and edit before deploying:
#   cp .env.example .env && nano .env

# JWT secret — MUST be at least 32 characters!
JWT_SECRET=super-secret-change-this-in-production-min32

JWT_EXPIRES_IN=7d

# Port to expose the app on (default: 80)
APP_PORT=80

# Allowed CORS origin (should match your domain)
CORS_ORIGIN=http://localhost

# Database: "xlsx" (default, persistent) | "memory" (tests only)
# DB_TYPE=xlsx
# DB_DATA_DIR=/app/data
