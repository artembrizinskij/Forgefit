# ── Forgefit API — environment variables ─────────────────────────────────────
# These are read by the server container in docker-compose.
# Copy to .env (at repo root) and edit before deploying.

# Server port (default: 3000)
PORT=3000

# !! REQUIRED — change before production deployment !!
JWT_SECRET=super-secret-key-change-in-production

# Token lifetime: 7d | 24h | 60m
JWT_EXPIRES_IN=7d

# Comma-separated allowed CORS origins
CORS_ORIGIN=http://localhost:5173
